{
  "name": "eng-njd",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:web:clean": "npm run dev:clean --workspace=apps/web",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:migrate:deploy": "npm run prisma:migrate:deploy --workspace=apps/api",
    "db:seed": "npm run prisma:seed --workspace=apps/api",
    "db:seed:production": "npm run prisma:seed:production --workspace=apps/api",
    "db:generate": "npm run prisma:generate --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
