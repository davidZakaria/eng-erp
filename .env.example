# PostgreSQL
DATABASE_URL="postgresql://eng_njd:eng_njd_secret@localhost:5432/eng_njd?schema=public"

# JWT
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="8h"

# MinIO (S3-compatible)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="password123"
MINIO_CAD_BUCKET="cad-files"
MINIO_BACKUP_BUCKET="backups"

# S3 / MinIO pre-signed uploads
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=eng-njd-documents

# Backup encryption (32-byte hex key for AES-256)
BACKUP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# pg_dump path (adjust for your OS)
PG_DUMP_PATH="pg_dump"

# API
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"
