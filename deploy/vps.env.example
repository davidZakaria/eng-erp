# Copy to deploy/vps.env on the VPS and fill every value.
# NEVER commit deploy/vps.env — it contains secrets.

NODE_ENV=production

# Public site (DuckDNS)
PUBLIC_HOST=eng-njd.duckdns.org
PUBLIC_URL=https://eng-njd.duckdns.org
CORS_ORIGIN=https://eng-njd.duckdns.org

# DuckDNS (host cron — see deploy/duckdns-update.sh)
DUCKDNS_SUBDOMAIN=eng-njd
DUCKDNS_TOKEN=your-duckdns-token

# PostgreSQL
POSTGRES_USER=eng_njd
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=eng_njd
DATABASE_URL=postgresql://eng_njd:change-me-strong-postgres-password@postgres:5432/eng_njd?schema=public

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_IN=8h
TRUST_PROXY=1
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# MinIO / S3 (internal + public paths)
MINIO_ROOT_USER=eng_njd_minio
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=eng_njd_minio
MINIO_SECRET_KEY=change-me-strong-minio-password
MINIO_CAD_BUCKET=cad-files
MINIO_BACKUP_BUCKET=backups
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://eng-njd.duckdns.org/s3
S3_ACCESS_KEY=eng_njd_minio
S3_SECRET_KEY=change-me-strong-minio-password
S3_BUCKET_NAME=eng-njd-documents

# Backup encryption — generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
PG_DUMP_PATH=pg_dump

# API / Web (localhost ports — host nginx proxies DuckDNS here)
API_PORT=3001
API_URL=http://api:3001
ENG_NJD_WEB_PORT=13000
ENG_NJD_MINIO_PORT=19000

# Production seed — Super Admin only (run once after first deploy)
# Quote values that contain spaces or $ characters.
SEED_MODE=production
SEED_SUPER_ADMIN_PASSWORD='set-your-strong-super-admin-password'
SUPER_ADMIN_EMAIL=super@eng-njd.local
SUPER_ADMIN_NAME='System Super Admin'
