generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  HEAD_ENGINEER
  SITE_ENGINEER
  CONSULTANT
  ARCH_CONSULTANT
  STRUCT_CONSULTANT
  MEP_CONSULTANT
}

enum ModelStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUESTED
  APPROVED_FOR_CONSTRUCTION
  SUPERSEDED
}

enum Discipline {
  ARCHITECTURAL
  STRUCTURAL
  MEP
  INFRASTRUCTURE
}

enum ItemStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUESTED
  APPROVED_FOR_CONSTRUCTION
  DEVIATION_PENDING_OWNER
  SUPERSEDED
}

enum PanelPhase {
  R
  Y
  B
}

enum TrackerStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         Role      @default(SITE_ENGINEER)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  modelSubmissions ModelSubmission[] @relation("ConsultantSubmissions")
  modelReviews     ModelReview[]     @relation("ReviewerReviews")
  auditLogs        AuditLog[]
  boqsCreated      ComponentBOQ[]    @relation("BoqCreator")
  executionLogs    ExecutionLog[]    @relation("SiteEngineerLogs")
  uploadedDrawings Drawing[]
  conversations    Conversation[]    @relation("UserConversations")
  messages         Message[]
  chatModeration   ChatModeration?
  pourTrackerLogs  PourTrackerEntry[] @relation("PourTrackerLogger")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  targetTable String
  targetId    String?
  oldData     Json?
  newData     Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model SystemBackup {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  status    String   @default("SUCCESS")
  createdAt DateTime @default(now())
}

model Project {
  id        String    @id @default(cuid())
  name      String
  code      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  buildings        Building[]
  modelSubmissions ModelSubmission[]
}

model Building {
  id        String    @id @default(cuid())
  projectId String
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project    Project             @relation(fields: [projectId], references: [id])
  components BuildingComponent[]
}

model BuildingComponent {
  id         String    @id @default(cuid())
  buildingId String
  name       String
  type       String
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  building      Building       @relation(fields: [buildingId], references: [id])
  boq           ComponentBOQ?
  executionLogs ExecutionLog[]
}

model ModelSubmission {
  id            String      @id @default(cuid())
  projectId     String
  consultantId  String
  title         String
  fileUrl       String
  versionNumber Int
  status        ModelStatus @default(DRAFT)
  isLocked      Boolean     @default(false)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project      Project       @relation(fields: [projectId], references: [id])
  consultant   User          @relation("ConsultantSubmissions", fields: [consultantId], references: [id])
  reviews      ModelReview[]
  executionLogs ExecutionLog[]

  @@index([projectId, title])
}

model ModelReview {
  id                 String      @id @default(cuid())
  modelSubmissionId  String
  reviewerId         String
  statusDecision     ModelStatus
  comments           String
  createdAt          DateTime    @default(now())

  modelSubmission ModelSubmission @relation(fields: [modelSubmissionId], references: [id])
  reviewer        User            @relation("ReviewerReviews", fields: [reviewerId], references: [id])
}

model ComponentBOQ {
  id                    String    @id @default(cuid())
  buildingComponentId   String    @unique
  plannedConcreteM3     Float
  plannedRebarByDiameter Json
  plannedStartDate      DateTime
  plannedEndDate        DateTime
  createdById           String
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  buildingComponent BuildingComponent @relation(fields: [buildingComponentId], references: [id])
  createdBy         User              @relation("BoqCreator", fields: [createdById], references: [id])
}

model ExecutionLog {
  id                    String    @id @default(cuid())
  buildingComponentId   String
  siteEngineerId        String
  modelSubmissionId     String?
  actualConcreteM3      Float
  actualRebarByDiameter Json
  actualPourDate        DateTime
  notes                 String?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  buildingComponent BuildingComponent @relation(fields: [buildingComponentId], references: [id])
  siteEngineer      User              @relation("SiteEngineerLogs", fields: [siteEngineerId], references: [id])
  modelSubmission   ModelSubmission?  @relation(fields: [modelSubmissionId], references: [id])
}

model CSIDivision {
  id         String             @id @default(uuid())
  code       String             @unique
  title      String
  vendors    ApprovedVendor[]
  submittals MaterialSubmittal[]
}

model ApprovedVendor {
  id            String              @id @default(uuid())
  name          String
  country       String?
  disciplineTag String?
  divisionId    String
  csiDivision   CSIDivision         @relation(fields: [divisionId], references: [id])
  submittals    MaterialSubmittal[]
}

model SpecSection {
  id           String    @id @default(uuid())
  code         String    @unique
  title        String
  divisionCode String
  fileUrl      String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submittals MaterialSubmittal[]
}

model Drawing {
  id             String     @id @default(uuid())
  drawingNumber  String
  title          String
  discipline     Discipline
  revision       Int        @default(0)
  status         ItemStatus @default(PENDING_REVIEW)
  fileUrl        String
  uploaderId     String
  projectNumber  String?
  disciplineCode String?
  sheetNumber    String?
  sheetSize      String?
  scale          String?
  packageName    String?
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  uploader User @relation(fields: [uploaderId], references: [id])

  @@unique([drawingNumber, revision])
}

model PourClearance {
  id                  String   @id @default(uuid())
  zone                String
  floorLevel          String
  formworkApproved    Boolean  @default(false)
  rebarApproved       Boolean  @default(false)
  ptCablesXApproved   Boolean  @default(false)
  ptCablesYApproved   Boolean  @default(false)
  isLockedByNCR       Boolean  @default(false)
  isLockedByMEP       Boolean  @default(false)
  isLockedByDefect    Boolean  @default(false)
  status              String   @default("PENDING")
  updatedAt           DateTime @updatedAt
}

model NonConformanceReport {
  id          String   @id @default(uuid())
  ncrNumber   String   @unique
  description String
  severity    String
  status      String   @default("OPEN")
  floorLevel  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MaterialSubmittal {
  id                   String     @id @default(uuid())
  equipmentTag         String
  proposedVendor       String
  isApprovedVendor     Boolean
  equivalenceLetterUrl String?
  leadTimeWeeks        Int?
  costDeltaEGP         Float?
  systemRecommendation String?
  status               ItemStatus @default(PENDING_REVIEW)
  divisionId           String
  specSectionId        String?
  csiDivision          CSIDivision     @relation(fields: [divisionId], references: [id])
  vendorId             String?
  vendor               ApprovedVendor? @relation(fields: [vendorId], references: [id])
  specSection          SpecSection?    @relation(fields: [specSectionId], references: [id])
}

model ElectricalPanel {
  id             String         @id @default(uuid())
  panelReference String         @unique
  location       String
  incomingCB     String
  isUnbalanced   Boolean        @default(false)
  circuits       PanelCircuit[]
}

model PanelCircuit {
  id              String          @id @default(uuid())
  circuitNumber   Int
  mcbRating       Float
  wireSize        String
  loadType        String
  connectedLoadVA Float
  demandFactor    Float
  phase           PanelPhase
  panelId         String
  panel           ElectricalPanel @relation(fields: [panelId], references: [id])
}

model BOQItem {
  id              String @id @default(uuid())
  itemCode        String
  description     String
  unit            String
  plannedQuantity Float
  rateEGP         Float
  actualQuantity  Float  @default(0)
  divisionCode    String?
}

model SiteDefect {
  id          String   @id @default(uuid())
  description String
  location    String
  severity    String   @default("HIGH")
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}

model RFI {
  id          String   @id @default(uuid())
  rfiNumber   String   @unique
  question    String
  answer      String?
  status      String   @default("OPEN")
  impactsCost Boolean  @default(false)
  dueDate     DateTime
  createdAt   DateTime @default(now())
}

model Conversation {
  id        String    @id @default(uuid())
  name      String?
  isGroup   Boolean   @default(false)
  isGlobal  Boolean   @default(false)
  users     User[]    @relation("UserConversations")
  messages  Message[]
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(uuid())
  content        String
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
}

model ChatModeration {
  userId       String    @id
  user         User      @relation(fields: [userId], references: [id])
  warningCount Int       @default(0)
  bannedUntil  DateTime?
  updatedAt    DateTime  @updatedAt
}

model PourTrackerEntry {
  id                  String         @id @default(cuid())
  buildingLabel       String
  halfZone            String?
  floorLevel          String?
  elementType         String
  elementLabel        String?
  rebarByDiameter     Json           @default("{}")
  concreteM3          Float?
  rebarCostEGP        Float?
  concreteCostEGP     Float?
  laborCostEGP        Float?
  plannedDurationDays Int?
  plannedStart        DateTime?
  plannedEnd          DateTime?
  actualPourDate      DateTime?
  status              TrackerStatus  @default(PLANNED)
  sourceRow           Int?
  notes               String?
  loggedById          String?
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  loggedBy User? @relation("PourTrackerLogger", fields: [loggedById], references: [id])

  @@index([buildingLabel, floorLevel])
}

model SchedulePlan {
  id            String    @id @default(cuid())
  name          String
  projectLabel  String?
  planDeadline  DateTime?
  buildingCodes String[]
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lines         ScheduleLine[]
}

model ScheduleLine {
  id            String   @id @default(cuid())
  planId        String
  itemCode      String
  parentCode    String?
  description   String
  unit          String?
  categoryLabel String?
  sortOrder     Int      @default(0)
  plan          SchedulePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  progress      ScheduleBuildingProgress[]

  @@index([planId, sortOrder])
}

model ScheduleBuildingProgress {
  id           String    @id @default(cuid())
  lineId       String
  buildingCode String
  quantity     Float?
  rateEGP      Float?
  durationDays Int?
  startDate    DateTime?
  endDate      DateTime?
  lineTotalEGP Float?
  status       String?
  line         ScheduleLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([lineId, buildingCode])
}
